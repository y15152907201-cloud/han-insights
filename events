    { id:'ev3', date:'2026-09-22', title:'Annual Economic Outlook Conference',                       type:'Conference', location:'Seoul',  time:'9:00 AM KST',  description:"Han Insights' flagship annual event featuring research presentations, panel discussions, and networking sessions." },
