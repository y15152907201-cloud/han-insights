<script>
  // SUPABASE
  const SUPABASE_URL = 'https://iofzbkiafkeqchjtoppt.supabase.co';
  const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImlvZnpia2lhZmtlcWNoanRvcHB0Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODA4MTQ3ODMsImV4cCI6MjA5NjM5MDc4M30.xaUyd2iYthuLbTGyqdI8U1gLLv3TXqiuUSnvsou94g4';
  const sb = window.supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

  // EVENTS DATA
  const EV_EVENTS = [
    { id:'ev1', date:'2026-07-18', title:'Global Supply Chain Risk: What Executives Need to Know', type:'Webinar',    location:'Online', time:'10:00 AM KST', description:'A live session covering emerging disruptions in Asia-Pacific supply chains, with case-based analysis and a Q&A segment.' },
