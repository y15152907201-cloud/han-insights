<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Events — Han Insights</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
</head>
<body>

<!-- ============================================================
     HEADER
     ============================================================ -->
<header class="header" id="mainHeader">
  <div class="header-left" onclick="window.location.href='index.html'">
    <span style="font-family:'Playfair Display',serif;font-size:18px;font-weight:700;">Han Insights</span>
  </div>
  <nav class="header-nav">
    <a href="index.html">Research</a>
    <a href="index.html">Newsletter</a>
    <a class="active">Education</a>
    <a href="index.html">About Us</a>
  </nav>
  <div class="header-right">
    <span class="guest-badge" id="headerGuestBadge">Guest</span>
    <div class="dropdown" id="userDropdown">
      <div style="display:flex;align-items:center;gap:8px;cursor:pointer;" onclick="toggleDropdown()">
        <div class="avatar-btn" id="headerAvatar"><span style="font-size:16px;">👤</span></div>
        <div class="menu-icon"><span></span><span></span><span></span></div>
      </div>
      <div class="dropdown-panel" id="dropdownPanel"></div>
    </div>
  </div>
</header>


<!-- ============================================================
     PAGE: EVENTS
     ============================================================ -->
<div id="page-events">

  <div class="page-hero">
    <p class="page-hero-label">Han Insights — Education</p>
    <h1 class="page-hero-title">Events</h1>
    <p class="page-hero-sub">Workshops, seminars, and speaking engagements — learn alongside leading practitioners.</p>
  </div>

  <div class="inner-section">

    <!-- MY REGISTRATIONS (only when logged in) -->
    <div id="evMyBlock" style="display:none; margin-bottom:64px;">
      <p class="section-label">My Registrations</p>
      <div class="ev-grid" id="evMyGrid"></div>
    </div>

    <!-- UPCOMING -->
    <div style="margin-bottom:64px;">
      <p class="section-label">Upcoming Events</p>
      <div class="ev-grid" id="evUpcomingGrid"></div>
    </div>

    <!-- PAST -->
    <div style="margin-bottom:40px;">
      <p class="section-label">Past Events</p>
      <div class="ev-grid" id="evPastGrid"></div>
    </div>

  </div>
</div>


<!-- ============================================================
     MODAL: REGISTER
     ============================================================ -->
<div class="ev-overlay" id="evOverlay" onclick="evCloseModal(event)">
  <div class="ev-modal">
    <button class="ev-modal-close" onclick="evCloseModalDirect()">✕</button>

    <div class="ev-modal-header">
      <p class="ev-modal-label">Register for Event</p>
      <h2 class="ev-modal-title" id="evModalTitle"></h2>
      <div class="ev-modal-meta" id="evModalMeta"></div>
    </div>

    <div class="ev-modal-body">
      <div id="evFormSection">
        <h3 class="ev-form-heading">Your Details</h3>
        <p class="ev-form-sub">Fill in your information and we'll send a confirmation to your email.</p>
        <div class="ev-error" id="evFormError"></div>
        <div class="ev-field">
          <label>Full Name *</label>
          <input type="text" id="evName" placeholder="Jane Smith">
        </div>
        <div class="ev-field">
          <label>Email Address *</label>
          <input type="email" id="evEmail" placeholder="jane@example.com">
        </div>
        <div class="ev-field">
          <label>Phone Number</label>
          <input type="tel" id="evPhone" placeholder="+82 10 0000 0000">
        </div>
        <button class="ev-submit-btn" id="evSubmitBtn" onclick="evSubmit()">Confirm Registration →</button>
      </div>

      <div class="ev-success" id="evSuccess">
        <div class="ev-success-icon">✉️</div>
        <h3 class="ev-success-title">You're Registered!</h3>
        <p class="ev-success-sub">A confirmation has been sent to <strong id="evSuccessEmail"></strong>.<br>We look forward to seeing you there.</p>
        <button class="ev-done-btn" onclick="evCloseModalDirect()">Done</button>
      </div>
    </div>
  </div>
</div>


<!-- ============================================================
     LOGIN MODAL
     ============================================================ -->
<div class="ev-overlay" id="loginOverlay" onclick="loginCloseModal(event)">
  <div class="ev-modal">
    <button class="ev-modal-close" onclick="document.getElementById('loginOverlay').classList.remove('open');document.body.style.overflow=''">✕</button>
    <div class="ev-modal-header">
      <p class="ev-modal-label">Han Insights</p>
      <h2 class="ev-modal-title" id="loginModalTitle">Sign In</h2>
      <p style="font-size:13px;opacity:0.7;margin-top:6px;" id="loginModalSub">Welcome back to Han Insights.</p>
    </div>
    <div class="ev-modal-body">
      <div class="ev-error" id="loginError"></div>
      <div class="ev-success" id="loginSuccessMsg" style="display:none;text-align:left;padding:0 0 16px;">
        <p class="ev-success-sub" id="loginSuccessText"></p>
      </div>
      <button class="google-btn" onclick="loginWithGoogle()">
        <svg width="18" height="18" viewBox="0 0 24 24"><path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/><path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/><path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l3.66-2.84z"/><path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/></svg>
        Continue with Google
      </button>
      <div class="login-divider">or</div>
      <div class="ev-field"><label>Email</label><input type="email" id="loginEmail" placeholder="your@email.com"></div>
      <div class="ev-field"><label>Password</label><input type="password" id="loginPassword" placeholder="••••••••"></div>
      <button class="ev-submit-btn" onclick="submitAuth()" id="loginBtn">Sign In</button>
      <div class="login-toggle">
        <span id="loginToggleText">Don't have an account? </span>
        <span onclick="toggleAuthMode()" id="loginToggleLink">Sign up</span>
      </div>
    </div>
  </div>
</div>


<!-- ============================================================
     FOOTER
     ============================================================ -->
<footer>
  <span>© 2026 Han Insights. All rights reserved.</span>
  <div style="display:flex;gap:24px;">
    <a href="index.html">About</a>
    <a href="index.html">Newsletter</a>
    <a href="#">Privacy</a>
  </div>
</footer>


<!-- ============================================================
     STYLE
     ============================================================ -->
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --dark-burgundy: #1a0505;
    --white: #ffffff;
    --black: #111111;
    --border: #e0e0e0;
    --vip-gold: #c9a84c;
  }
  body { font-family: 'DM Sans', sans-serif; background: var(--white); color: var(--black); padding-top: 57px; }

  /* HEADER */
  .header { display: flex; justify-content: space-between; align-items: center; padding: 14px 36px; border-bottom: 1px solid var(--border); position: fixed; top: 0; left: 0; right: 0; background: white; z-index: 100; transition: box-shadow 0.35s ease; }
  .header.scrolled { box-shadow: 0 2px 12px rgba(0,0,0,0.07); }
  .header-left { display: flex; align-items: center; gap: 10px; cursor: pointer; }
  .header-nav { display: flex; gap: 44px; align-items: center; }
  .header-nav a { text-decoration: none; color: var(--black); font-size: 13px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; transition: opacity 0.2s; cursor: pointer; }
  .header-nav a:hover { opacity: 0.5; }
  .header-nav a.active { border-bottom: 2px solid var(--black); padding-bottom: 2px; }
  .header-right { display: flex; align-items: center; gap: 10px; position: relative; }
  .avatar-btn { width: 32px; height: 32px; border-radius: 50%; border: 1.5px solid #ccc; cursor: pointer; background: #ebebeb; display: flex; align-items: center; justify-content: center; font-size: 14px; overflow: hidden; }
  .menu-icon { cursor: pointer; display: flex; flex-direction: column; gap: 4px; padding: 4px; }
  .menu-icon span { display: block; width: 18px; height: 1.5px; background: var(--black); }
  .guest-badge { font-size: 11px; letter-spacing: 0.08em; text-transform: uppercase; color: #999; border: 1px solid #ddd; padding: 4px 10px; border-radius: 2px; }
  .dropdown { position: relative; }
  .dropdown-panel { display: none; position: absolute; top: calc(100% + 12px); right: 0; background: white; border: 1px solid var(--border); min-width: 200px; z-index: 999; box-shadow: 0 4px 16px rgba(0,0,0,0.08); }
  .dropdown-panel a { display: block; padding: 11px 16px; font-size: 13px; color: var(--black); text-decoration: none; border-bottom: 1px solid #f0f0f0; transition: background 0.15s; cursor: pointer; }
  .dropdown-panel a:last-child { border-bottom: none; }
  .dropdown-panel a:hover { background: #f8f8f8; }
  .dropdown-panel .dropdown-logout { color: #c00; }
  .dropdown.open .dropdown-panel { display: block; }

  /* PAGE HERO */
  .page-hero { background: var(--dark-burgundy); padding: 80px 36px 60px; color: white; }
  .page-hero-label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.6; margin-bottom: 16px; }
  .page-hero-title { font-family: 'Playfair Display', serif; font-size: 48px; font-weight: 700; line-height: 1.15; max-width: 600px; }
  .page-hero-sub { font-size: 15px; opacity: 0.7; margin-top: 16px; max-width: 500px; line-height: 1.6; }

  /* INNER */
  .inner-section { padding: 64px 36px; max-width: 1100px; margin: 0 auto; }
  .section-label { font-size: 11px; font-weight: 500; letter-spacing: 0.14em; text-transform: uppercase; color: #888; margin-bottom: 28px; border-bottom: 1px solid var(--border); padding-bottom: 12px; }

  /* EVENTS GRID */
  .ev-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 28px; }
  .ev-empty { grid-column: 1/-1; border: 1px solid var(--border); padding: 48px; text-align: center; color: #aaa; font-size: 14px; background: #fafafa; }

  /* CARD */
  .ev-card { background: white; border: 1px solid var(--border); overflow: hidden; cursor: pointer; transition: box-shadow 0.2s, transform 0.2s; }
  .ev-card:hover { box-shadow: 0 8px 32px rgba(0,0,0,0.09); transform: translateY(-2px); }
  .ev-card.ev-past { opacity: 0.68; filter: grayscale(20%); cursor: default; }
  .ev-card.ev-past:hover { box-shadow: none; transform: none; }
  .ev-card.ev-registered { border: 2px solid var(--dark-burgundy); }
  .ev-card-top { background: var(--dark-burgundy); color: white; padding: 28px 28px 22px; display: flex; justify-content: space-between; align-items: flex-start; }
  .ev-card.ev-past .ev-card-top { background: #888; }
  .ev-date-block .ev-month { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; opacity: 0.65; margin-bottom: 2px; }
  .ev-date-block .ev-day { font-family: 'Playfair Display', serif; font-size: 42px; font-weight: 700; line-height: 1; }
  .ev-date-block .ev-year { font-size: 11px; opacity: 0.45; margin-top: 4px; }
  .ev-badges { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .ev-badge { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; padding: 4px 10px; font-weight: 500; }
  .ev-badge-type     { background: rgba(255,255,255,0.15); color: white; }
  .ev-badge-upcoming { background: white; color: var(--dark-burgundy); }
  .ev-badge-past     { background: rgba(255,255,255,0.12); color: rgba(255,255,255,0.6); }
  .ev-badge-reg      { background: var(--vip-gold); color: white; }
  .ev-card-body { padding: 24px 28px 28px; }
  .ev-card-tag { font-size: 10px; letter-spacing: 0.12em; text-transform: uppercase; color: #888; margin-bottom: 8px; }
  .ev-card-title { font-family: 'Playfair Display', serif; font-size: 22px; line-height: 1.35; margin-bottom: 10px; color: var(--black); }
  .ev-card-meta { display: flex; gap: 16px; font-size: 12px; color: #aaa; margin-bottom: 14px; flex-wrap: wrap; }
  .ev-card-desc { font-size: 14px; line-height: 1.75; color: #555; margin-bottom: 20px; }
  .ev-cta { display: inline-block; font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; color: var(--black); background: none; border: none; border-bottom: 1px solid var(--black); padding-bottom: 2px; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: opacity 0.2s; }
  .ev-cta:hover { opacity: 0.5; }
  .ev-cta.ev-cta-ended { color: #bbb; border-bottom-color: #ddd; cursor: default; }
  .ev-cta.ev-cta-ended:hover { opacity: 1; }
  .ev-cta.ev-cta-registered { color: var(--dark-burgundy); border-bottom-color: var(--dark-burgundy); cursor: default; }
  .ev-cta.ev-cta-registered:hover { opacity: 1; }

  /* OVERLAY */
  .ev-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.40); z-index: 500; align-items: center; justify-content: center; padding: 20px; }
  .ev-overlay.open { display: flex; }
  .ev-modal { background: white; width: 100%; max-width: 520px; max-height: 90vh; overflow-y: auto; position: relative; box-shadow: 0 4px 40px rgba(0,0,0,0.14); animation: evModalIn 0.25s ease; }
  @keyframes evModalIn { from { opacity: 0; transform: translateY(16px); } to { opacity: 1; transform: none; } }
  .ev-modal-close { position: absolute; top: 14px; right: 18px; background: none; border: none; color: white; font-size: 22px; cursor: pointer; opacity: 0.65; line-height: 1; z-index: 10; }
  .ev-modal-close:hover { opacity: 1; }
  .ev-modal-header { background: var(--dark-burgundy); color: white; padding: 36px 40px 28px; }
  .ev-modal-label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; opacity: 0.6; margin-bottom: 10px; }
  .ev-modal-title { font-family: 'Playfair Display', serif; font-size: 24px; line-height: 1.3; margin-bottom: 14px; font-weight: 700; }
  .ev-modal-meta { display: flex; gap: 18px; font-size: 13px; opacity: 0.75; flex-wrap: wrap; }
  .ev-modal-body { padding: 36px 40px 40px; }
  .ev-form-heading { font-family: 'Playfair Display', serif; font-size: 22px; margin-bottom: 6px; }
  .ev-form-sub { font-size: 14px; color: #666; margin-bottom: 28px; line-height: 1.7; }
  .ev-error { background: #fff0f0; border: 1px solid #fcc; color: #c00; padding: 10px 14px; font-size: 13px; margin-bottom: 16px; display: none; }
  .ev-field { margin-bottom: 20px; }
  .ev-field label { display: block; font-size: 11px; letter-spacing: 0.1em; text-transform: uppercase; color: #888; margin-bottom: 6px; }
  .ev-field input { width: 100%; padding: 12px 14px; border: 1px solid var(--border); background: white; font-size: 14px; font-family: 'DM Sans', sans-serif; outline: none; color: var(--black); transition: border-color 0.2s; }
  .ev-field input:focus { border-color: var(--black); }
  .ev-submit-btn { width: 100%; padding: 14px; background: var(--black); color: white; border: none; font-size: 13px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; cursor: pointer; font-family: 'DM Sans', sans-serif; transition: background 0.2s; margin-top: 8px; }
  .ev-submit-btn:hover { background: #333; }
  .ev-submit-btn:disabled { background: #aaa; cursor: not-allowed; }
  .ev-success { display: none; text-align: center; padding: 8px 0 4px; }
  .ev-success-icon { font-size: 40px; margin-bottom: 14px; }
  .ev-success-title { font-family: 'Playfair Display', serif; font-size: 24px; margin-bottom: 10px; }
  .ev-success-sub { font-size: 14px; color: #666; line-height: 1.75; }
  .ev-done-btn { display: inline-block; margin-top: 22px; padding: 12px 32px; background: var(--black); color: white; border: none; cursor: pointer; font-size: 12px; font-weight: 500; letter-spacing: 0.08em; text-transform: uppercase; font-family: 'DM Sans', sans-serif; transition: background 0.2s; }
  .ev-done-btn:hover { background: #333; }

  /* LOGIN MODAL EXTRAS */
  .google-btn { width: 100%; padding: 13px; background: white; color: #333; border: 1.5px solid var(--border); cursor: pointer; font-size: 13px; font-weight: 500; display: flex; align-items: center; justify-content: center; gap: 10px; transition: background 0.2s; margin-bottom: 4px; font-family: 'DM Sans', sans-serif; }
  .google-btn:hover { background: #f8f8f8; }
  .login-divider { display: flex; align-items: center; gap: 12px; margin: 18px 0; color: #ccc; font-size: 12px; }
  .login-divider::before, .login-divider::after { content: ''; flex: 1; height: 1px; background: var(--border); }
  .login-toggle { margin-top: 14px; text-align: center; font-size: 13px; color: #888; }
  .login-toggle span { color: var(--black); cursor: pointer; border-bottom: 1px solid var(--black); }

  /* FOOTER */
  footer { border-top: 1px solid var(--border); padding: 32px 36px; display: flex; justify-content: space-between; align-items: center; font-size: 12px; color: #888; }
  footer a { color: #888; text-decoration: none; cursor: pointer; }
  footer a:hover { color: var(--black); }

  @media (max-width: 768px) {
    .header { padding: 12px 18px; }
    .header-nav { display: none; }
    .ev-grid { grid-template-columns: 1fr; }
    .inner-section { padding: 40px 18px 60px; }
    .page-hero { padding: 56px 18px 40px; }
    .page-hero-title { font-size: 34px; }
    .ev-modal-header { padding: 26px 22px 20px; }
    .ev-modal-body { padding: 26px 22px 30px; }
    footer { flex-direction: column; gap: 12px; text-align: center; }
  }
</style>


