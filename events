    { id:'ev5', date:'2026-01-20', title:'2026 Market Outlook Briefing',                             type:'Webinar',    location:'Online', time:'10:00 AM KST', description:"Han Insights' annual January briefing covering macro trends, sector outlooks, and key risks to watch." },
    { id:'ev6', date:'2025-11-08', title:'Northeast Asia Trade Dynamics',                            type:'Seminar',    location:'Seoul',  time:'3:00 PM KST',  description:'Examining trade flows, geopolitical pressures, and strategic opportunities across the Northeast Asian corridor.' }
  ];

  const MONTHS = ['JAN','FEB','MAR','APR','MAY','JUN','JUL','AUG','SEP','OCT','NOV','DEC'];
  let currentUser = null;
  let evRegistrations = [];
  let evActive = null;
  let authMode = 'signin';

  // AUTH INIT
  async function initAuth() {
    const s = await sb.auth.getSession();
    if (s.data.session) currentUser = s.data.session.user;
    sb.auth.onAuthStateChange(function(event, session) {
      currentUser = session ? session.user : null;
      renderAuthUI();
      if (event === 'SIGNED_IN') {
        document.getElementById('loginOverlay').classList.remove('open');
        document.body.style.overflow = '';
        evRenderAll();
      }
    });
    renderAuthUI();
  }

  function isLoggedIn() { return currentUser !== null; }

  function renderAuthUI() {
    const guestBadge = document.getElementById('headerGuestBadge');
    const avatar     = document.getElementById('headerAvatar');
    const panel      = document.getElementById('dropdownPanel');
    guestBadge.style.display = isLoggedIn() ? 'none' : 'inline';
    if (isLoggedIn()) {
      const meta = currentUser.user_metadata;
      avatar.innerHTML = meta && meta.avatar_url
        ? '<img src="'+meta.avatar_url+'" style="width:100%;height:100%;object-fit:cover;border-radius:50%;">'
        : '<span style="font-size:13px;background:#e8e0d0;width:100%;height:100%;display:flex;align-items:center;justify-content:center;border-radius:50%;">'+(currentUser.email[0].toUpperCase())+'</span>';
      panel.innerHTML =
        '<a onclick="window.location.href=\'index.html\'">Back to Home</a>'+
        '<a onclick="logout()">Logout</a>';
    } else {
      avatar.innerHTML = '<span style="font-size:16px;">👤</span>';
      panel.innerHTML =
        '<a onclick="openLoginModal()">Login / Sign Up</a>'+
        '<a onclick="window.location.href=\'index.html\'">Back to Home</a>';
    }
  }

  async function loginWithGoogle() {
    await sb.auth.signInWithOAuth({ provider: 'google', options: { redirectTo: window.location.href } });
  }

  async function submitAuth() {
    const email    = document.getElementById('loginEmail').value.trim();
    const password = document.getElementById('loginPassword').value;
    const errEl    = document.getElementById('loginError');
    errEl.style.display = 'none';
    if (!email || !password) { errEl.textContent = 'Please enter email and password.'; errEl.style.display = 'block'; return; }
    const res = authMode === 'signin'
      ? await sb.auth.signInWithPassword({ email, password })
      : await sb.auth.signUp({ email, password });
    if (res.error) { errEl.textContent = res.error.message; errEl.style.display = 'block'; }
    else if (authMode === 'signup') {
      const suc = document.getElementById('loginSuccessMsg');
      document.getElementById('loginSuccessText').textContent = '✓ Account created! Check your email to verify.';
      suc.style.display = 'block';
    }
  }

  function toggleAuthMode() {
    authMode = authMode === 'signin' ? 'signup' : 'signin';
    document.getElementById('loginModalTitle').textContent = authMode === 'signin' ? 'Sign In' : 'Create Account';
    document.getElementById('loginModalSub').textContent   = authMode === 'signin' ? 'Welcome back to Han Insights.' : 'Join Han Insights today.';
    document.getElementById('loginBtn').textContent        = authMode === 'signin' ? 'Sign In' : 'Create Account';
    document.getElementById('loginToggleText').textContent = authMode === 'signin' ? "Don't have an account? " : 'Already have an account? ';
    document.getElementById('loginToggleLink').textContent = authMode === 'signin' ? 'Sign up' : 'Sign in';
  }

  async function logout() {
    await sb.auth.signOut();
    currentUser = null;
    renderAuthUI();
    document.getElementById('userDropdown').classList.remove('open');
    evRenderAll();
  }

  function openLoginModal() {
    document.getElementById('userDropdown').classList.remove('open');
    document.getElementById('loginError').style.display = 'none';
    document.getElementById('loginSuccessMsg').style.display = 'none';
    document.getElementById('loginEmail').value = '';
    document.getElementById('loginPassword').value = '';
    document.getElementById('loginOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function loginCloseModal(e) {
    if (e.target === document.getElementById('loginOverlay')) {
      document.getElementById('loginOverlay').classList.remove('open');
      document.body.style.overflow = '';
    }
  }

  // DROPDOWN
  function toggleDropdown() { document.getElementById('userDropdown').classList.toggle('open'); }
  document.addEventListener('click', function(e) {
    const d = document.getElementById('userDropdown');
    if (!d.contains(e.target)) d.classList.remove('open');
  });

  // HEADER SCROLL
  window.addEventListener('scroll', function() {
    document.getElementById('mainHeader').classList.toggle('scrolled', window.scrollY > 10);
  });

  // EVENTS: LOAD REGISTRATIONS
  async function evLoadRegs() {
    evRegistrations = [];
    if (!isLoggedIn()) return;
    try {
      const res = await sb.from('event_registrations').select('event_id').eq('user_id', currentUser.id);
      if (!res.error && res.data) evRegistrations = res.data.map(r => r.event_id);
    } catch(e) {}
  }

  function evIsPast(d) { const t = new Date(); t.setHours(0,0,0,0); return new Date(d+'T00:00:00') < t; }
  function evIsReg(id) { return evRegistrations.includes(id); }

  // EVENTS: RENDER CARD
  function evCard(ev) {
    const d    = new Date(ev.date+'T00:00:00');
    const past = evIsPast(ev.date);
    const reg  = evIsReg(ev.id);

    const statusBadge = past
      ? '<span class="ev-badge ev-badge-past">Past</span>'
      : '<span class="ev-badge ev-badge-upcoming">Upcoming</span>';
    const regBadge = reg ? '<span class="ev-badge ev-badge-reg">✓ Registered</span>' : '';

    let cta = '';
    if (past)     cta = '<button class="ev-cta ev-cta-ended" disabled>Event Ended</button>';
    else if (reg) cta = '<button class="ev-cta ev-cta-registered" disabled>✓ Registered</button>';
    else          cta = `<button class="ev-cta" onclick="event.stopPropagation();evOpenModal('${ev.id}')">Register Now →</button>`;

    const clickable = !past && !reg;
    return `
      <div class="ev-card${past?' ev-past':''}${reg?' ev-registered':''}" ${clickable?`onclick="evOpenModal('${ev.id}')"`:''}> 
        <div class="ev-card-top">
          <div class="ev-date-block">
            <div class="ev-month">${MONTHS[d.getMonth()]}</div>
            <div class="ev-day">${d.getDate()}</div>
            <div class="ev-year">${d.getFullYear()}</div>
          </div>
          <div class="ev-badges">
            <span class="ev-badge ev-badge-type">${ev.type}</span>
            ${statusBadge}${regBadge}
          </div>
        </div>
        <div class="ev-card-body">
          <div class="ev-card-tag">${ev.type} · ${MONTHS[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}</div>
          <div class="ev-card-title">${ev.title}</div>
          <div class="ev-card-meta">
            <span>📍 ${ev.location}</span>
            <span>🕐 ${ev.time}</span>
          </div>
          <p class="ev-card-desc">${ev.description}</p>
          ${cta}
        </div>
      </div>`;
  }

  // EVENTS: RENDER ALL
  async function evRenderAll() {
    await evLoadRegs();
    const upcoming = EV_EVENTS.filter(e => !evIsPast(e.date)).sort((a,b) => new Date(a.date)-new Date(b.date));
    const past     = EV_EVENTS.filter(e =>  evIsPast(e.date)).sort((a,b) => new Date(b.date)-new Date(a.date));
    const myRegs   = EV_EVENTS.filter(e =>  evIsReg(e.id));

    const myBlock = document.getElementById('evMyBlock');
    if (isLoggedIn() && myRegs.length) {
      myBlock.style.display = 'block';
      document.getElementById('evMyGrid').innerHTML = myRegs.map(evCard).join('');
    } else {
      myBlock.style.display = 'none';
    }

    document.getElementById('evUpcomingGrid').innerHTML = upcoming.length
      ? upcoming.map(evCard).join('')
      : '<div class="ev-empty">No upcoming events scheduled — check back soon.</div>';

    document.getElementById('evPastGrid').innerHTML = past.length
      ? past.map(evCard).join('')
      : '<div class="ev-empty">No past events on record.</div>';
  }

  // EVENTS: MODAL
  function evOpenModal(id) {
    evActive = EV_EVENTS.find(e => e.id === id);
    if (!evActive) return;
    const d = new Date(evActive.date+'T00:00:00');
    document.getElementById('evModalTitle').textContent = evActive.title;
    document.getElementById('evModalMeta').innerHTML =
      `<span>📍 ${evActive.location}</span><span>🕐 ${evActive.time}</span><span>📅 ${MONTHS[d.getMonth()]} ${d.getDate()}, ${d.getFullYear()}</span>`;
    document.getElementById('evName').value  = currentUser?.user_metadata?.full_name || '';
    document.getElementById('evEmail').value = currentUser?.email || '';
    document.getElementById('evPhone').value = '';
    document.getElementById('evFormError').style.display = 'none';
    document.getElementById('evFormSection').style.display = 'block';
    document.getElementById('evSuccess').style.display = 'none';
    document.getElementById('evSubmitBtn').disabled = false;
    document.getElementById('evSubmitBtn').textContent = 'Confirm Registration →';
    document.getElementById('evOverlay').classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function evCloseModal(e) { if (e.target === document.getElementById('evOverlay')) evCloseModalDirect(); }
  function evCloseModalDirect() { document.getElementById('evOverlay').classList.remove('open'); document.body.style.overflow = ''; }
  document.addEventListener('keydown', e => { if (e.key === 'Escape') { evCloseModalDirect(); document.getElementById('loginOverlay').classList.remove('open'); document.body.style.overflow=''; } });

  // EVENTS: SUBMIT REGISTRATION
  async function evSubmit() {
    const name  = document.getElementById('evName').value.trim();
    const email = document.getElementById('evEmail').value.trim();
    const phone = document.getElementById('evPhone').value.trim();
    const errEl = document.getElementById('evFormError');
    errEl.style.display = 'none';
    if (!name)  { errEl.textContent = 'Please enter your full name.';      errEl.style.display = 'block'; return; }
    if (!email) { errEl.textContent = 'Please enter your email address.';  errEl.style.display = 'block'; return; }
    if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { errEl.textContent = 'Please enter a valid email address.'; errEl.style.display = 'block'; return; }

    const btn = document.getElementById('evSubmitBtn');
    btn.disabled = true; btn.textContent = 'Submitting…';

    try {
      await sb.from('event_registrations').insert({
        event_id:    evActive.id,
        event_title: evActive.title,
        event_date:  evActive.date,
        name, email,
        phone:   phone || null,
        user_id: currentUser?.id || null
      });

      if (!evRegistrations.includes(evActive.id)) evRegistrations.push(evActive.id);

      // TODO: plug in Resend email here when ready

      document.getElementById('evSuccessEmail').textContent = email;
      document.getElementById('evFormSection').style.display = 'none';
      document.getElementById('evSuccess').style.display = 'block';
      evRenderAll();
    } catch(err) {
      errEl.textContent = 'Submission failed: ' + err.message;
      errEl.style.display = 'block';
      btn.disabled = false;
      btn.textContent = 'Confirm Registration →';
    }
  }

  // INIT
  initAuth().then(() => evRenderAll());
</script>

</body>
</html>
